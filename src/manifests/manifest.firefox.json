{
  "manifest_version": 3,
  "name": "AdBlocker Pro",
  "short_name": "AdBlocker",
  "version": "1.0.0",
  "description": "Block ads, trackers, and malware. Fast, lightweight, and privacy-first.",
  "browser_specific_settings": {
    "gecko": {
      "id": "adblocker-pro@extension",
      "strict_min_version": "113.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "AdBlocker Pro"
  },
  "background": {
    "scripts": ["background/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "declarativeNetRequest",
    "browsingData",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ads",
        "enabled": true,
        "path": "rules/ads.json"
      },
      {
        "id": "privacy",
        "enabled": true,
        "path": "rules/privacy.json"
      },
      {
        "id": "malware",
        "enabled": true,
        "path": "rules/malware.json"
      }
    ]
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
